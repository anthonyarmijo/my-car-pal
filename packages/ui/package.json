{
  "name": "@my-car-pal/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "README.md",
    "src/components",
    "src/styles",
    "src/tokens",
    "src/index.ts",
    "src/utils.ts"
  ],
  "sideEffects": [
    "src/styles/*.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles.css": "./src/styles/index.css",
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "import": "./src/tokens/index.ts"
    },
    "./tokens.css": "./src/styles/tokens.css",
    "./tokens.json": "./src/tokens/tokens.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "check:boundary": "node scripts/check-boundary.mjs",
    "check:pack": "node scripts/check-pack.mjs",
    "check:tokens": "node scripts/check-tokens.mjs",
    "tokens:write": "node scripts/check-tokens.mjs --write",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
