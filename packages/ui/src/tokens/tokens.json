    "color.graphite.700": "--mcp-color-graphite-700",
    "color.porcelain.50": "--mcp-color-porcelain-50",
    "color.porcelain.100": "--mcp-color-porcelain-100",
    "color.sand.100": "--mcp-color-sand-100",
    "color.sand.200": "--mcp-color-sand-200",
    "color.taupe.500": "--mcp-color-taupe-500",
    "color.tobacco.600": "--mcp-color-tobacco-600",
    "color.tobacco.700": "--mcp-color-tobacco-700",
    "color.bluegray.500": "--mcp-color-bluegray-500",
    "color.bluegray.700": "--mcp-color-bluegray-700",
    "color.sage.600": "--mcp-color-sage-600",
