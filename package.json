{
  "name": "my-car-pal",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/ui"
  ],
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "predev": "npm run db:up",
    "dev": "node scripts/dev.mjs",
    "postinstall": "prisma generate",
    "prebuild": "prisma generate && node scripts/check-build-env.mjs",
    "build": "next build",
    "build:ui": "npm run build --workspace @my-car-pal/ui",
    "build-storybook": "storybook build",
    "check:ui-boundary": "npm run check:boundary --workspace @my-car-pal/ui",
    "check:ui-pack": "npm run check:pack --workspace @my-car-pal/ui",
    "check:ui-tokens": "npm run check:tokens --workspace @my-car-pal/ui",
    "test:design-system:routes": "node scripts/design-system-route-smoke.mjs",
    "test:design-system:rendered": "node scripts/design-system-rendered-smoke.mjs",
    "test:storybook:visual": "node scripts/storybook-visual-smoke.mjs",
    "verify:design-system": "node scripts/verify-design-system.mjs",
    "verify:storybook:visual": "npm run build-storybook && npm run test:storybook:visual",
    "start": "next start",
    "lint": "next lint",
    "storybook": "storybook dev -p 6006",
    "typecheck": "tsc --noEmit",
    "typecheck:ui": "npm run typecheck --workspace @my-car-pal/ui",
    "setup": "./scripts/dev-setup.sh",
    "reset": "./scripts/dev-reset.sh",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "catalog:sync": "node scripts/fetch-vpic-catalog.mjs",
    "catalog:sync:motorcycles": "node scripts/fetch-vpic-motorcycle-catalog.mjs",
    "catalog:images:review": "node scripts/prepare-default-vehicle-image-review.mjs --write",
    "catalog:images:validate": "node scripts/import-default-vehicle-images.mjs --check",
    "catalog:images:import": "node scripts/import-default-vehicle-images.mjs",
    "db:up": "docker compose up -d --wait postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres && sleep 2 && prisma migrate deploy",
    "db:studio": "prisma studio",
    "docker:up": "docker compose up --build -d app adminer",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "test:security:isolation": "node scripts/test-user-isolation.mjs"
  },
  "dependencies": {
    "@my-car-pal/ui": "file:packages/ui",
    "@prisma/client": "^6.19.2",
    "@shaggytools/nhtsa-api-wrapper": "^3.0.4",
    "@vercel/blob": "^2.3.2",
    "better-auth": "^1.5.4",
    "jose": "^6.1.0",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "pg": "^8.16.3",
    "playwright": "^1.57.0",
    "prisma": "^6.19.2",
    "storybook": "^10.4.6",
    "typescript": "^5.7.3",
    "vite": "^8.0.16"
  }
}
