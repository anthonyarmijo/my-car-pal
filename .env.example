# Local development (docker-compose postgres)
POSTGRES_HOST_PORT=55432
APP_HOST_PORT=3000
ADMINER_HOST_PORT=8080
DATABASE_URL=postgresql://mycarpal:mycarpal_dev@localhost:55432/mycarpal?schema=public
DIRECT_URL=postgresql://mycarpal:mycarpal_dev@localhost:55432/mycarpal?schema=public

# For quick local sqlite (no docker needed) — requires changing prisma/schema.prisma provider to "sqlite"
# DATABASE_URL=file:./dev.db

# Better Auth ---------------------------------------------------------------
# Generate a strong random secret: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Full public URL of your app (no trailing slash)
BETTER_AUTH_URL=http://localhost:3000
# Also expose to the browser for the auth client
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Optional social auth. Email/password works without provider secrets.
NEXT_PUBLIC_ENABLE_SOCIAL_AUTH=0
NEXT_PUBLIC_ENABLE_APPLE_AUTH=0

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In (https://developer.apple.com)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# File storage --------------------------------------------------------------
# local stores uploads under public/uploads and is the self-host default.
# vercel-blob is an optional managed adapter for private deployments.
FILE_STORAGE_DRIVER=local
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_ID=

# Hosted-service operational settings are not part of the self-hosted environment contract.
